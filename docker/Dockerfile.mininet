# Stage 1: Extract BMv2 binaries + libraries from p4c image.
FROM p4c:latest AS p4-tools

# Collect simple_switch, simple_switch_CLI, BMv2 runtime plugin directories,
# and all non-standard shared libraries they depend on into /p4-export/.
RUN mkdir -p /p4-export/bin /p4-export/lib /p4-export/py \
        /p4-export/usr-local-lib/libyang /p4-export/etc/sysrepo/yang && \
    cp /usr/local/bin/simple_switch /p4-export/bin/ && \
    cp /usr/local/bin/simple_switch_grpc /p4-export/bin/ && \
    cp /usr/local/bin/simple_switch_CLI /p4-export/bin/ && \
    # Copy /usr/local/lib shared objects needed by simple_switch.
    cp /usr/local/lib/lib*.so* /p4-export/lib/ && \
    cp -r /usr/local/lib/libyang/extensions /p4-export/usr-local-lib/libyang/ && \
    cp -r /usr/local/lib/libyang/user_types /p4-export/usr-local-lib/libyang/ && \
    cp -r /etc/sysrepo/yang/internal /p4-export/etc/sysrepo/yang/ && \
    # Copy non-glibc system libs that differ between Ubuntu 20.04 and 22.04.
    for lib in \
        /lib/x86_64-linux-gnu/libboost_program_options.so* \
        /lib/x86_64-linux-gnu/libboost_filesystem.so* \
        /lib/x86_64-linux-gnu/libboost_thread.so* \
        /lib/x86_64-linux-gnu/libpcap.so* \
        /lib/x86_64-linux-gnu/libgmp.so* \
        /lib/x86_64-linux-gnu/libssl.so.1.1 \
        /lib/x86_64-linux-gnu/libcrypto.so.1.1 \
        /lib/x86_64-linux-gnu/libprotobuf-c.so* \
        /lib/x86_64-linux-gnu/libev.so* \
        /usr/lib/x86_64-linux-gnu/libprotobuf-c.so* \
        /usr/lib/x86_64-linux-gnu/libev.so* \
        /usr/lib/x86_64-linux-gnu/libpcre.so* \
        /usr/lib/x86_64-linux-gnu/libz.so* \
        /usr/lib/libavl.so* \
    ; do cp "$lib" /p4-export/lib/ 2>/dev/null || true; done && \
    # Copy Python modules needed by simple_switch_CLI.
    cp /usr/local/lib/python3.8/site-packages/sswitch_CLI.py /p4-export/py/ && \
    cp /usr/local/lib/python3.8/site-packages/runtime_CLI.py /p4-export/py/ && \
    cp /usr/local/lib/python3.8/site-packages/bmpy_utils.py /p4-export/py/ && \
    cp -r /usr/local/lib/python3.8/site-packages/thrift /p4-export/py/ && \
    cp -r /usr/local/lib/python3.8/site-packages/bm_runtime /p4-export/py/ && \
    cp -r /usr/local/lib/python3.8/site-packages/sswitch_runtime /p4-export/py/

# Stage 2: Runtime image — Mininet + OVS + BMv2 + Python.
FROM iwaseyusuke/mininet

ENV DEBIAN_FRONTEND=noninteractive

# Need certificates plus git because the vendored vLLM build uses
# setuptools-scm/vcs-versioning during wheel preparation.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates ethtool git \
    && rm -rf /var/lib/apt/lists/*

# BMv2 binaries + shared libraries + plugin directories + Python CLI modules
# from Stage 1.
COPY --from=p4-tools /p4-export/bin/ /usr/local/bin/
COPY --from=p4-tools /p4-export/lib/ /usr/local/lib/
COPY --from=p4-tools /p4-export/usr-local-lib/libyang/ /usr/local/lib/libyang/
COPY --from=p4-tools /p4-export/etc/sysrepo/yang/ /etc/sysrepo/yang/
# simple_switch_CLI hardcodes /usr/local/lib/python3.8/site-packages, so
# install its Python support files at that exact path in the runtime image.
COPY --from=p4-tools /p4-export/py/ /usr/local/lib/python3.8/site-packages/
RUN rm -f /usr/local/lib/libanl.so /usr/local/lib/libanl.so.1 && ldconfig

# --- uv package manager ---
# uv can download its own standalone Python 3.12 — no PPA needed.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# --- Project setup ---
# Use a venv outside the project dir so it doesn't collide with the
# host's .venv when the project is bind-mounted at runtime.
ENV UV_PROJECT_ENVIRONMENT=/opt/kvswitch-venv

WORKDIR /kvswitch

# 1. Install locked third-party Python deps without installing the local
#    project yet.
COPY pyproject.toml uv.lock ./
RUN uv venv --python 3.12 \
    && uv sync --frozen --no-install-project

# 2. Install vendored vLLM in its own layer.
COPY .git/modules/3rdparty/vllm ./.git/modules/3rdparty/vllm
COPY 3rdparty/vllm ./3rdparty/vllm
RUN VLLM_USE_PRECOMPILED=1 \
    VLLM_PRECOMPILED_WHEEL_COMMIT=89a77b10846fd96273cce78d86d2556ea582d26e \
    uv pip install --python /opt/kvswitch-venv/bin/python3 ./3rdparty/vllm

# 3. Copy the runtime project files and install the local package.
COPY kvswitch ./kvswitch
COPY exp ./exp
COPY scripts ./scripts
COPY docker ./docker
COPY README.md ./
RUN uv pip install --python /opt/kvswitch-venv/bin/python3 --editable . --no-deps

ENTRYPOINT ["/kvswitch/docker/entrypoint.sh"]
CMD ["exp/run_eval.py"]
